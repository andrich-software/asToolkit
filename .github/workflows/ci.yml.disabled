name: CI

on:
  push:
    branches:
      - main
      - release/**

  pull_request:
    types: [opened, synchronize, reopened]
    branches:
      - main
      - release/**
env:
  STEP_TIMEOUT_MINUTES: 60

jobs:
  smoke_test:
    name: Smoke Test (Debug Build of asToolkit)
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Install Dependencies
        timeout-minutes: ${{ fromJSON(env.STEP_TIMEOUT_MINUTES) }}
        uses: "./.github/steps/install_dependencies"

      - name: Add MSBuild to PATH
        uses: microsoft/setup-msbuild@v2

      - name: Restore Solution
        run: dotnet restore asToolkit.sln

      - name: Build asToolkit Solution (Debug)
        run: dotnet build asToolkit.sln --configuration Debug --no-restore

  unit_test:
    name: Unit Tests
    runs-on: windows-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Install Dependencies
        timeout-minutes: ${{ fromJSON(env.STEP_TIMEOUT_MINUTES) }}
        uses: "./.github/steps/install_dependencies"

      - name: Add MSBuild to PATH
        uses: microsoft/setup-msbuild@v2

      - name: Restore Server Tests
        run: dotnet restore tests/asToolkit.Server.Tests/asToolkit.Server.Tests.csproj

      - name: Build Server Tests (Release)
        run: dotnet build tests/asToolkit.Server.Tests/asToolkit.Server.Tests.csproj --configuration Release --no-restore

      - name: Run Server Unit Tests
        run: dotnet test tests/asToolkit.Server.Tests/asToolkit.Server.Tests.csproj --no-build -c Release --logger GitHubActions --blame-crash --collect:"XPlat Code Coverage" -- DataCollectionRunSettings.DataCollectors.DataCollector.Configuration.Format=opencover

      - name: Restore Client Tests
        run: dotnet restore tests/asToolkit.Client.Tests/asToolkit.Client.Tests.csproj

      - name: Build Client Tests (Release)
        run: dotnet build tests/asToolkit.Client.Tests/asToolkit.Client.Tests.csproj --configuration Release --no-restore

      - name: Run Client Unit Tests
        run: dotnet test tests/asToolkit.Client.Tests/asToolkit.Client.Tests.csproj --no-build -c Release --logger GitHubActions --blame-crash --collect:"XPlat Code Coverage" -- DataCollectionRunSettings.DataCollectors.DataCollector.Configuration.Format=opencover
