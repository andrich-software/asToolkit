<Page x:Class="asToolkit.Client.Features.ProductAttributes.Views.ProductAttributeEditPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:asToolkit.Client.Features.ProductAttributes.Views"
      xmlns:models="using:asToolkit.Client.Features.ProductAttributes.Models"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header with NavigationBar -->
    <utu:NavigationBar Grid.Row="0"
                       Content="{Binding Title}">
      <utu:NavigationBar.PrimaryCommands>
        <AppBarButton x:Uid="ProductAttributeEditPage.AppBarButton.Cancel"
                      Click="CancelButton_Click">
          <AppBarButton.Icon>
            <FontIcon Glyph="&#xE711;" />
          </AppBarButton.Icon>
        </AppBarButton>
        <AppBarButton x:Uid="ProductAttributeEditPage.AppBarButton.Save"
                      Click="SaveButton_Click"
                      IsEnabled="{Binding CanSave}">
          <AppBarButton.Icon>
            <FontIcon Glyph="&#xE74E;" />
          </AppBarButton.Icon>
        </AppBarButton>
      </utu:NavigationBar.PrimaryCommands>
    </utu:NavigationBar>

    <!-- Form Content -->
    <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto">
      <Grid Padding="24">
        <!-- VisualStateManager for responsive layout -->
        <VisualStateManager.VisualStateGroups>
          <VisualStateGroup>
            <VisualState x:Name="Narrow">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="0" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="ContentStack.MaxWidth" Value="480" />
                <Setter Target="AttributeCard.Padding" Value="16" />
                <Setter Target="ValuesCard.Padding" Value="16" />
                <Setter Target="InfoCard.Padding" Value="16" />
              </VisualState.Setters>
            </VisualState>

            <VisualState x:Name="Medium">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="600" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="ContentStack.MaxWidth" Value="560" />
                <Setter Target="AttributeCard.Padding" Value="24" />
                <Setter Target="ValuesCard.Padding" Value="24" />
                <Setter Target="InfoCard.Padding" Value="20" />
              </VisualState.Setters>
            </VisualState>

            <VisualState x:Name="Wide">
              <VisualState.StateTriggers>
                <AdaptiveTrigger MinWindowWidth="900" />
              </VisualState.StateTriggers>
              <VisualState.Setters>
                <Setter Target="ContentStack.MaxWidth" Value="640" />
                <Setter Target="AttributeCard.Padding" Value="32" />
                <Setter Target="ValuesCard.Padding" Value="32" />
                <Setter Target="InfoCard.Padding" Value="24" />
              </VisualState.Setters>
            </VisualState>
          </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <StackPanel x:Name="ContentStack"
                    Spacing="24"
                    HorizontalAlignment="Center">

          <!-- Error Message Banner -->
          <Border Background="{ThemeResource ErrorContainerBrush}"
                  CornerRadius="12"
                  Padding="16"
                  Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <FontIcon Grid.Column="0"
                        Glyph="&#xE783;"
                        FontSize="20"
                        Foreground="{ThemeResource OnErrorContainerBrush}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center" />
              <TextBlock Grid.Column="1"
                         Text="{Binding ErrorMessage}"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnErrorContainerBrush}"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center" />
            </Grid>
          </Border>

          <!-- Loading Overlay -->
          <Border Background="{ThemeResource SurfaceBrush}"
                  CornerRadius="16"
                  Padding="32"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center"
                        Spacing="16">
              <ProgressRing IsActive="True"
                            Width="48"
                            Height="48" />
              <TextBlock x:Uid="Common.Loading"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Border>

          <!-- Main Attribute Card -->
          <Border x:Name="AttributeCard"
                  Background="{ThemeResource SurfaceBrush}"
                  CornerRadius="16"
                  Padding="24"
                  Translation="0,0,8"
                  Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border.Shadow>
              <ThemeShadow />
            </Border.Shadow>
            <StackPanel Spacing="24">
              <!-- Card Header with Icon -->
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Large Icon Circle -->
                <Border Grid.Column="0"
                        Width="56"
                        Height="56"
                        CornerRadius="28"
                        Background="{ThemeResource PrimaryContainerBrush}"
                        Margin="0,0,16,0">
                  <FontIcon Glyph="&#xE8EC;"
                            FontSize="24"
                            Foreground="{ThemeResource OnPrimaryContainerBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="4">
                  <TextBlock x:Uid="ProductAttributeEditPage.Section.AttributeDetails"
                             Style="{StaticResource TitleMedium}"
                             Foreground="{ThemeResource OnSurfaceBrush}" />
                  <TextBlock x:Uid="ProductAttributeEditPage.Section.AttributeDetails.Subtitle"
                             Style="{StaticResource BodySmall}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>
              </Grid>

              <!-- Divider -->
              <Border Height="1"
                      Background="{ThemeResource OutlineVariantBrush}" />

              <!-- Name Input -->
              <StackPanel Spacing="8">
                <TextBlock x:Uid="ProductAttributeEditPage.Field.Name.Label"
                           Style="{StaticResource LabelMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <TextBox x:Name="NameTextBox"
                         x:Uid="ProductAttributeEditPage.Field.Name"
                         Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNotLoading}"
                         HorizontalAlignment="Stretch" />
              </StackPanel>

              <!-- SortOrder Input -->
              <StackPanel Spacing="8">
                <TextBlock x:Uid="ProductAttributeEditPage.Field.SortOrder.Label"
                           Style="{StaticResource LabelMedium}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                <NumberBox x:Name="SortOrderNumberBox"
                           x:Uid="ProductAttributeEditPage.Field.SortOrder"
                           Value="{Binding SortOrder, Mode=TwoWay}"
                           SpinButtonPlacementMode="Inline"
                           SmallChange="1"
                           LargeChange="10"
                           Minimum="0"
                           IsEnabled="{Binding IsNotLoading}"
                           HorizontalAlignment="Stretch" />
                <!-- Helper Text -->
                <TextBlock x:Uid="ProductAttributeEditPage.Field.SortOrder.HelperText"
                           Style="{StaticResource LabelSmall}"
                           Foreground="{ThemeResource OnSurfaceVariantBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Values Card -->
          <Border x:Name="ValuesCard"
                  Background="{ThemeResource SurfaceBrush}"
                  CornerRadius="16"
                  Padding="24"
                  Translation="0,0,8"
                  Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border.Shadow>
              <ThemeShadow />
            </Border.Shadow>
            <StackPanel Spacing="16">
              <!-- Card Header with Icon -->
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="56"
                        Height="56"
                        CornerRadius="28"
                        Background="{ThemeResource TertiaryContainerBrush}"
                        Margin="0,0,16,0">
                  <FontIcon Glyph="&#xE8FD;"
                            FontSize="24"
                            Foreground="{ThemeResource OnTertiaryContainerBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="4">
                  <TextBlock x:Uid="ProductAttributeEditPage.Section.Values"
                             Style="{StaticResource TitleMedium}"
                             Foreground="{ThemeResource OnSurfaceBrush}" />
                  <TextBlock x:Uid="ProductAttributeEditPage.Section.Values.Subtitle"
                             Style="{StaticResource BodySmall}"
                             Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                </StackPanel>
              </Grid>

              <!-- Divider -->
              <Border Height="1"
                      Background="{ThemeResource OutlineVariantBrush}" />

              <!-- Value Rows -->
              <ItemsControl ItemsSource="{Binding Values}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,0,0,8">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <TextBox Grid.Column="0"
                               x:Uid="ProductAttributeEditPage.Field.Value"
                               Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               HorizontalAlignment="Stretch"
                               Margin="0,0,8,0" />

                      <NumberBox Grid.Column="1"
                                 x:Uid="ProductAttributeEditPage.Field.ValueSortOrder"
                                 Value="{Binding SortOrder, Mode=TwoWay}"
                                 SpinButtonPlacementMode="Hidden"
                                 Minimum="0"
                                 HorizontalAlignment="Stretch"
                                 Margin="0,0,8,0" />

                      <Button Grid.Column="2"
                              Style="{StaticResource IconButtonStyle}"
                              x:Uid="ProductAttributeEditPage.Button.RemoveValue"
                              Click="RemoveValue_Click"
                              VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE74D;"
                                  FontSize="16"
                                  Foreground="{ThemeResource ErrorBrush}" />
                      </Button>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- Add Value Button -->
              <Button x:Uid="ProductAttributeEditPage.Button.AddValue"
                      Style="{StaticResource OutlinedButtonStyle}"
                      Click="AddValue_Click"
                      HorizontalAlignment="Left" />
            </StackPanel>
          </Border>

          <!-- Info Card -->
          <Border x:Name="InfoCard"
                  Background="{ThemeResource SecondaryContainerBrush}"
                  CornerRadius="12"
                  Padding="20"
                  Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <FontIcon Grid.Column="0"
                        Glyph="&#xE946;"
                        FontSize="20"
                        Foreground="{ThemeResource OnSecondaryContainerBrush}"
                        Margin="0,0,12,0"
                        VerticalAlignment="Top" />
              <TextBlock Grid.Column="1"
                         x:Uid="ProductAttributeEditPage.Info.UsageHint"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSecondaryContainerBrush}"
                         TextWrapping="Wrap" />
            </Grid>
          </Border>

          <!-- Action Buttons (Mobile-friendly) -->
          <Grid Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                Margin="0,8,0,24">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    x:Uid="ProductAttributeEditPage.Button.Cancel"
                    Style="{StaticResource OutlinedButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Click="CancelButton_Click"
                    MinHeight="48" />

            <Button Grid.Column="2"
                    x:Uid="ProductAttributeEditPage.Button.Save"
                    Style="{StaticResource FilledButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Click="SaveButton_Click"
                    IsEnabled="{Binding CanSave}"
                    MinHeight="48" />
          </Grid>

        </StackPanel>
      </Grid>
    </ScrollViewer>
  </Grid>
</Page>
