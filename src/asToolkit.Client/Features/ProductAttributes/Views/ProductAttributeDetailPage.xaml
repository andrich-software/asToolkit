<Page x:Class="asToolkit.Client.Features.ProductAttributes.Views.ProductAttributeDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:asToolkit.Client.Features.ProductAttributes.Views"
      xmlns:models="using:asToolkit.Client.Features.ProductAttributes.Models"
      xmlns:mvux="using:Uno.Extensions.Reactive.UI"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="{ThemeResource BackgroundBrush}">

  <Grid utu:SafeArea.Insets="VisibleBounds">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header with back button -->
    <utu:NavigationBar Grid.Row="0" x:Uid="ProductAttributeDetailPage.NavigationBar">
      <utu:NavigationBar.MainCommand>
        <AppBarButton Icon="Back"
                      x:Uid="ProductAttributeDetailPage.AppBarButton.Back"
                      Click="BackButton_Click" />
      </utu:NavigationBar.MainCommand>
      <utu:NavigationBar.PrimaryCommands>
        <AppBarButton Icon="Edit"
                      x:Uid="ProductAttributeDetailPage.AppBarButton.Edit"
                      Click="EditButton_Click" />
      </utu:NavigationBar.PrimaryCommands>
    </utu:NavigationBar>

    <!-- Product Attribute Details Content -->
    <mvux:FeedView Grid.Row="1"
                   Source="{Binding ProductAttribute}">
      <mvux:FeedView.ValueTemplate>
        <DataTemplate>
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Padding="24">
              <!-- VisualStateManager for responsive layout -->
              <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                  <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                      <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                      <Setter Target="ContentStack.MaxWidth" Value="400" />
                    </VisualState.Setters>
                  </VisualState>

                  <VisualState x:Name="Medium">
                    <VisualState.StateTriggers>
                      <AdaptiveTrigger MinWindowWidth="600" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                      <Setter Target="ContentStack.MaxWidth" Value="500" />
                    </VisualState.Setters>
                  </VisualState>

                  <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                      <AdaptiveTrigger MinWindowWidth="900" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                      <Setter Target="ContentStack.MaxWidth" Value="600" />
                    </VisualState.Setters>
                  </VisualState>
                </VisualStateGroup>
              </VisualStateManager.VisualStateGroups>

              <StackPanel x:Name="ContentStack"
                          Spacing="24"
                          MaxWidth="500"
                          HorizontalAlignment="Center">

                <!-- Attribute Hero Card -->
                <Border Background="{ThemeResource SurfaceBrush}"
                        CornerRadius="16"
                        Padding="32"
                        Translation="0,0,8">
                  <Border.Shadow>
                    <ThemeShadow />
                  </Border.Shadow>
                  <StackPanel HorizontalAlignment="Center"
                              Spacing="16">
                    <!-- Attribute Icon -->
                    <Border Width="80"
                            Height="80"
                            CornerRadius="40"
                            Background="{ThemeResource PrimaryContainerBrush}"
                            HorizontalAlignment="Center">
                      <FontIcon Glyph="&#xE8EC;"
                                FontSize="36"
                                Foreground="{ThemeResource OnPrimaryContainerBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                    </Border>

                    <!-- Attribute Name Display -->
                    <TextBlock Text="{Binding Data.Name}"
                               Style="{StaticResource HeadlineMedium}"
                               Foreground="{ThemeResource PrimaryBrush}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />

                    <!-- Attribute Label -->
                    <TextBlock x:Uid="ProductAttributeDetailPage.Field.Attribute"
                               Style="{StaticResource TitleMedium}"
                               Foreground="{ThemeResource OnSurfaceVariantBrush}"
                               HorizontalAlignment="Center" />
                  </StackPanel>
                </Border>

                <!-- Information Card -->
                <Border Background="{ThemeResource SurfaceBrush}"
                        CornerRadius="12"
                        Translation="0,0,8">
                  <Border.Shadow>
                    <ThemeShadow />
                  </Border.Shadow>
                  <StackPanel Spacing="0">
                    <!-- Card Header -->
                    <Grid Padding="16,16,16,8">
                      <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE946;"
                                  FontSize="20"
                                  Foreground="{ThemeResource TertiaryBrush}"
                                  Margin="0,0,12,0" />
                        <TextBlock x:Uid="ProductAttributeDetailPage.Section.Information"
                                   Style="{StaticResource TitleMedium}"
                                   Foreground="{ThemeResource OnSurfaceBrush}" />
                      </StackPanel>
                    </Grid>

                    <!-- Information Fields -->
                    <StackPanel Padding="16,0,16,16"
                                Spacing="16">
                      <!-- Name Field -->
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0"
                                  Glyph="&#xE8EC;"
                                  FontSize="16"
                                  Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1">
                          <TextBlock x:Uid="ProductAttributeDetailPage.Field.Name"
                                     Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          <TextBlock Text="{Binding Data.Name}"
                                     Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceBrush}" />
                        </StackPanel>
                      </Grid>

                      <!-- SortOrder Field -->
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0"
                                  Glyph="&#xE8CB;"
                                  FontSize="16"
                                  Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                  Margin="0,0,12,0"
                                  VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1">
                          <TextBlock x:Uid="ProductAttributeDetailPage.Field.SortOrder"
                                     Style="{StaticResource LabelSmall}"
                                     Foreground="{ThemeResource OnSurfaceVariantBrush}" />
                          <TextBlock Text="{Binding Data.SortOrder}"
                                     Style="{StaticResource BodyMedium}"
                                     Foreground="{ThemeResource OnSurfaceBrush}" />
                        </StackPanel>
                      </Grid>
                    </StackPanel>
                  </StackPanel>
                </Border>

                <!-- Values Card -->
                <Border Background="{ThemeResource SurfaceBrush}"
                        CornerRadius="12"
                        Translation="0,0,8">
                  <Border.Shadow>
                    <ThemeShadow />
                  </Border.Shadow>
                  <StackPanel Spacing="0">
                    <!-- Card Header -->
                    <Grid Padding="16,16,16,8">
                      <StackPanel Orientation="Horizontal">
                        <FontIcon Glyph="&#xE8FD;"
                                  FontSize="20"
                                  Foreground="{ThemeResource TertiaryBrush}"
                                  Margin="0,0,12,0" />
                        <TextBlock x:Uid="ProductAttributeDetailPage.Section.Values"
                                   Style="{StaticResource TitleMedium}"
                                   Foreground="{ThemeResource OnSurfaceBrush}" />
                      </StackPanel>
                    </Grid>

                    <!-- Value Rows -->
                    <ItemsRepeater ItemsSource="{Binding Data.Values}"
                                   Margin="16,0,16,16">
                      <ItemsRepeater.Layout>
                        <StackLayout Orientation="Vertical" Spacing="0" />
                      </ItemsRepeater.Layout>
                      <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                          <Grid Padding="0,10"
                                BorderBrush="{ThemeResource OutlineVariantBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*" />
                              <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Value}"
                                       Style="{StaticResource BodyMedium}"
                                       Foreground="{ThemeResource OnSurfaceBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SortOrder}"
                                       Style="{StaticResource BodySmall}"
                                       Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                       VerticalAlignment="Center" />
                          </Grid>
                        </DataTemplate>
                      </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                  </StackPanel>
                </Border>

                <!-- Usage Hint Card -->
                <Border Background="{ThemeResource SecondaryContainerBrush}"
                        CornerRadius="12"
                        Padding="16">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0"
                              Glyph="&#xE946;"
                              FontSize="20"
                              Foreground="{ThemeResource OnSecondaryContainerBrush}"
                              Margin="0,0,12,0"
                              VerticalAlignment="Top" />
                    <TextBlock Grid.Column="1"
                               x:Uid="ProductAttributeDetailPage.UsageHint"
                               Style="{StaticResource BodyMedium}"
                               Foreground="{ThemeResource OnSecondaryContainerBrush}"
                               TextWrapping="Wrap" />
                  </Grid>
                </Border>
              </StackPanel>
            </Grid>
          </ScrollViewer>
        </DataTemplate>
      </mvux:FeedView.ValueTemplate>

      <mvux:FeedView.ProgressTemplate>
        <DataTemplate>
          <Grid HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="16">
              <ProgressRing IsActive="True"
                            Width="48"
                            Height="48" />
              <TextBlock x:Uid="Common.Loading"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ProgressTemplate>

      <mvux:FeedView.ErrorTemplate>
        <DataTemplate>
          <Grid HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <StackPanel Spacing="16">
              <FontIcon Glyph="&#xE783;"
                        FontSize="48"
                        Foreground="{ThemeResource ErrorBrush}" />
              <TextBlock x:Uid="ProductAttributeDetailPage.LoadError"
                         Style="{StaticResource BodyMedium}"
                         Foreground="{ThemeResource OnSurfaceVariantBrush}"
                         HorizontalAlignment="Center" />
              <Button x:Uid="Common.Retry"
                      Style="{StaticResource FilledButtonStyle}"
                      HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </DataTemplate>
      </mvux:FeedView.ErrorTemplate>
    </mvux:FeedView>
  </Grid>
</Page>
