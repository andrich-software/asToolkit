{% sw_extends '@Storefront/storefront/layout/meta.html.twig' %}

{# Inject the maERP tracker into the head. The endpoint is a same-origin route on this storefront; the
   secret token is added server-side in the collector controller and never appears here. #}
{% block layout_head_javascript_tracking %}
    {{ parent() }}

    <script>
        window.maerpTrackConfig = window.maerpTrackConfig || {};
        window.maerpTrackConfig.endpoint = '{{ path('frontend.maerp.collect') }}';
    </script>
    <script defer src="{{ asset('bundles/maerpanalytics/maerp-s.js') }}"></script>
    <script defer src="{{ asset('bundles/maerpanalytics/maerp-sw.js') }}"></script>
{% endblock %}
