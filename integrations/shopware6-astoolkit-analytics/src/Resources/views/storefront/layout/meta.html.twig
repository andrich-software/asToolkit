{% sw_extends '@Storefront/storefront/layout/meta.html.twig' %}

{# Inject the asToolkit tracker into the head. The endpoint is a same-origin route on this storefront; the
   secret token is added server-side in the collector controller and never appears here. #}
{% block layout_head_javascript_tracking %}
    {{ parent() }}

    <script>
        window.astoolkitTrackConfig = window.astoolkitTrackConfig || {};
        window.astoolkitTrackConfig.endpoint = '{{ path('frontend.astoolkit.collect') }}';
    </script>
    <script defer src="{{ asset('bundles/astoolkitanalytics/astoolkit-s.js') }}"></script>
    <script defer src="{{ asset('bundles/astoolkitanalytics/astoolkit-sw.js') }}"></script>
{% endblock %}
